# Database Configuration
DB_HOST=localhost
DB_PORT=3316
DB_USER=root
DB_PASSWORD=youruncle
DB_NAME=bob_db

# Slack Configuration
# Get these from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# OpenAI Configuration
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key

# Azure DevOps Configuration
# Format: https://dev.azure.com/your-organization
ADO_ORG_URL=https://dev.azure.com/your-org
ADO_PROJECT=YourProject
# Get PAT from Azure DevOps: User Settings -> Personal Access Tokens
ADO_PAT=your-personal-access-token

# Logging Configuration (optional - these have defaults)
LOG_LEVEL=INFO
LOG_FILE=logs/bob.log

# Session Cache Configuration (optional - these have defaults)
# Maximum number of conversations to cache in memory
SESSION_CACHE_MAX_SIZE=10000
# Time-to-live for cached conversations in seconds (28800 = 8 hours)
SESSION_CACHE_TTL_SECONDS=28800
